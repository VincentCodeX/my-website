---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="文森｜關於我" description="關於我和我的工作">
  <Navigation />

  <main class="about-page">
    <div class="container">
      <h1 class="page-title">關於我</h1>

      <div class="content-grid">
        <section class="content-section intro-section">
          <h2>你好！我是黃昇瑞</h2>
          <p>
            我是文森，一個持續在摸索創作與工具的人。
            目前專注在遊戲內容與 AI 應用的結合，慢慢找出適合自己的節奏。
          </p>
          <p>
            我主要製作遊戲相關的內容，包含攻略、體驗分享，以及一些實驗性的 AI 應用。
            也會把學到的東西整理成比較好理解的形式，讓自己和別人都能用得上。
          </p>
        </section>

        <section class="content-section">
          <h2>我在做什麼</h2>
          <div class="what-i-do-grid">
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <circle cx="12" cy="12" r="6"></circle>
                  <circle cx="12" cy="12" r="2"></circle>
                </svg>
              </div>
              <h3>AI 工具探索</h3>
              <p>持續嘗試各種 AI 工具，把它們變成日常可用的幫手，像是 Gemini、ChatGPT、Claude 等，慢慢整理出適合自己的使用方式。</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
              </div>
              <h3>網頁架構</h3>
              <p>自己動手打造網站，從架構到部署都親自嘗試。目前主要使用 Astro、Cloudflare、GitHub 和 Visual Studio Code，一步一步把想法變成實際的頁面。</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="2" y1="12" x2="22" y2="12"></line>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
              </div>
              <h3>YouTube 影片</h3>
              <p>經營 YouTube 頻道，內容以遊戲為主，包含攻略、開箱，以及 AI 相關分享，也慢慢嘗試不同類型的題材。</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                </svg>
              </div>
              <h3>AI 自動化工具</h3>
              <p>透過 AI 與 API 的搭配，製作一些讓工作更省力的小工具。目前多應用在影片剪輯流程與日常處理上，讓原本繁瑣的事情變得簡單一點。</p>
            </div>
          </div>
        </section>

        <section class="content-section">
          <h2>我的方法</h2>
          <p>
            我習慣用「先做出來，再慢慢優化」的方式前進。
          </p>
          <p>
            不追求完美，而是讓每一次產出都比上一次更清楚一點。
          </p>
        </section>

        <section class="content-section cta-section">
          <h2>與我聯繫</h2>
          <p>如果你對我的內容有興趣，或剛好也在做類似的事情，都可以透過我的頻道或網站聯繫我，一起交流也不錯。</p>
          <div class="contact-buttons">
            <a href={`${base}projects/`} class="btn btn-primary">
              看看我的專案
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
            <a href={`${base}blog/`} class="btn btn-secondary">閱讀我的部落格</a>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .about-page {
    min-height: 100vh;
    padding: calc(var(--nav-height) + 2rem) 2rem 5rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--color-text);
  }

  .content-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .content-section {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
  }

  .content-section h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .content-section p {
    line-height: 1.7;
    color: var(--color-text-dim);
    margin-bottom: 1rem;
  }

  .content-section p:last-of-type {
    margin-bottom: 0;
  }

  .what-i-do-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .service-card {
    padding: 1.25rem;
    background: rgba(59, 130, 246, 0.05);
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
  }

  .service-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(59, 130, 246, 0.1);
  }

  .service-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59, 130, 246, 0.1);
    border-radius: 0.5rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .service-card h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .service-card p {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    margin: 0;
    line-height: 1.5;
  }

  .cta-section {
    text-align: center;
  }

  .cta-section p {
    margin-bottom: 1.5rem;
  }

  .contact-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-body);
    text-decoration: none;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
  }

  .btn-primary:hover {
    background: #2563EB;
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.5);
  }

  .btn-primary svg {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover svg {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: rgba(59, 130, 246, 0.1);
    border-color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .about-page {
      padding-top: calc(var(--nav-height) + 1rem);
    }

    .what-i-do-grid {
      grid-template-columns: 1fr;
    }

    .contact-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>
